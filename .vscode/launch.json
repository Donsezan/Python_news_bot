{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Bot",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Dry Run",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["--dry-run"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}
